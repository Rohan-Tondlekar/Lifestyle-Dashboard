# ──────────────────────────────────────────────
# LOCAL DEVELOPMENT
# ──────────────────────────────────────────────

# SQLite — used locally, no setup needed
DATABASE_URL=sqlite:///dev.db

# Any string works locally
SECRET_KEY=dev-secret-key-change-me

# ISO date you started the program
PROGRAM_START_DATE=2026-06-02


# ──────────────────────────────────────────────
# PRODUCTION (Railway + Supabase)
# ──────────────────────────────────────────────
# Replace DATABASE_URL above with this when testing against Supabase locally.
# Set these as environment variables in Railway — never commit the real values.
#
# Get your connection string from:
#   Supabase → Project Settings → Database → Connection string → URI
#
# DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres?sslmode=require&options=-csearch_path%3Dlifestyle
#
# SECRET_KEY=generate with: python -c "import secrets; print(secrets.token_hex(32))"
#
# PROGRAM_START_DATE=2026-06-02
